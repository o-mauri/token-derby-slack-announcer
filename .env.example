# token-derby webhook_secret (printed once by `token-derby organisation webhook set`).
WEBHOOK_SECRET=

# Slack bot user OAuth token (xoxb-...).
SLACK_BOT_TOKEN=

# Slack channel ID, not name (e.g. C0123ABCDEF).
SLACK_CHANNEL_ID=

# Organisation name whose weekly leaderboard the announcer posts (Friday 3pm Europe/London).
TOKEN_DERBY_ORG_NAME=

# Optional. token-derby API base URL. Defaults to https://token-derby.mauricode.co.uk.
TOKEN_DERBY_API_BASE=
